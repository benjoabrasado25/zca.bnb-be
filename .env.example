# ===========================================
# ZCA BnB Backend - Environment Variables
# Copy this file to .env and update values
# ===========================================

# Django Settings
# ----------------
DEBUG=False
SECRET_KEY=your-super-secret-key-generate-with-django-secret-key-generator
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app,your-custom-domain.com

# Database (PostgreSQL)
# ---------------------
# Option 1: Use DATABASE_URL (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Option 2: Individual settings (used if DATABASE_URL is not set)
DB_NAME=zcabnb
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432

# CORS (Frontend URLs)
# --------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.railway.app,https://your-custom-domain.com

# JWT Authentication
# ------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Redis (for Caching & Celery)
# ----------------------------
REDIS_URL=redis://localhost:6379/0

# Celery (Background Tasks)
# -------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# iCal Sync Settings
# ------------------
ICAL_SYNC_INTERVAL_HOURS=1

# Logging
# -------
DJANGO_LOG_LEVEL=INFO

# ===========================================
# Railway Deployment Notes
# ===========================================
# 1. Add PostgreSQL addon in Railway
# 2. DATABASE_URL is auto-injected by Railway
# 3. Set SECRET_KEY in Railway variables
# 4. Set ALLOWED_HOSTS to include your Railway domain
# 5. Optionally add Redis addon for caching/Celery
